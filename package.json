{
  "name": "playwright-pom-framework",
  "version": "1.0.0",
  "description": "Playwright test automation framework using Page Object Model",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "test:report": "npx playwright show-report",
    "test:chrome": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:webkit": "npx playwright test --project=webkit",
    "test:docker": "powershell -ExecutionPolicy Bypass -File ./scripts/run-playwright-docker.ps1",
    "test:docker:smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/run-playwright-docker.ps1 -TestArgs \"--grep @smoke\"",
    "codegen": "npx playwright codegen",
    "start": "node src/server.js",
    "runapi": "npx playwright test --grep @api",
    "generate:allure": "npx allure generate ./allure-results -o ./allure-report",
    "open:allure": "npx allure open ./allure-report",
    "runapiwithallure": "npm run runapi && npm run generate:allure && npm run open:allure"
  },
  "devDependencies": {
    "@azure/identity": "^4.13.0",
    "@azure/playwright": "^1.1.2",
    "@playwright/mcp": "^0.0.68",
    "@playwright/test": "^1.50.0",
    "@reportportal/agent-js-playwright": "^5.4.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.15",
    "allure-commandline": "^2.38.0",
    "allure-playwright": "^3.6.0",
    "monocart-reporter": "^2.10.0",
    "typescript": "^5.7.0",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  }
}
